# ── Supabase (required) ───────────────────────────────────────────────
# Get from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Owner Upstox Token (optional but recommended) ─────────────────────
# Set this to YOUR Upstox access token.
# Users will then NOT need to enter a token — they just sign in and scan.
# Leave blank to require each user to enter their own token.
VITE_OWNER_UPSTOX_TOKEN=your_upstox_access_token_here
